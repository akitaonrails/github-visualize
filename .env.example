# Copy to .env and fill in. NEVER commit .env — it is gitignored.

# Required: Rails secret (generate with: openssl rand -hex 64)
SECRET_KEY_BASE=

# Required: GitHub token with read access to the repos you want to monitor
# (a fine-grained token with Contents:read + Actions:read is enough)
GITHUB_TOKEN=

# Host port to expose the app on
PORT=7592

# Timezone used to bucket charts by day/hour
APP_TIME_ZONE=America/Sao_Paulo

# Host path for the SQLite databases volume
#STORAGE_PATH=./storage

# Match the host user for volume permissions (defaults to 1000:1000)
#UID=1000
#GID=1000
