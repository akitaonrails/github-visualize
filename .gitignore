# Ignore all environment files (keep templates)
.env*
!.env.example

# Ignore bundler config and vendored gems
/.bundle
/vendor/bundle

# Ignore all default key files
/config/master.key
/config/credentials/*.key

# Ignore SQLite databases
/db/*.sqlite3
/db/*.sqlite3-*

# Ignore all logfiles and tempfiles
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
/tmp/pids/*
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases)
/storage/*
!/storage/.keep

# Ignore assets
/app/assets/builds/*
!/app/assets/builds/.keep
/node_modules

# Ignore coverage reports
/coverage
