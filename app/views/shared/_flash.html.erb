<% if notice.present? %>
  <p class="mt-4 text-sm text-emerald-300 border border-emerald-900 bg-emerald-950/40 rounded px-3 py-2"><%= notice %></p>
<% end %>
<% if alert.present? %>
  <p class="mt-4 text-sm text-red-300 border border-red-900 bg-red-950/40 rounded px-3 py-2"><%= alert %></p>
<% end %>
