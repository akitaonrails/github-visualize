<% content_for :title, "GitHub Visualize — dashboard" %>

<div class="flex items-end justify-between gap-4 flex-wrap">
  <div>
    <p class="text-xs text-neutral-500 uppercase tracking-widest mb-1">monitored repositories</p>
    <h1 class="text-4xl font-bold text-neutral-50"><%= @repositories.size %> <span class="text-neutral-500 text-2xl">repos</span></h1>
  </div>

  <%= form_with url: repositories_path, method: :post, class: "flex gap-2" do |form| %>
    <%= form.text_field :full_name, placeholder: "owner/repository",
          class: "bg-neutral-900 border border-neutral-700 rounded px-3 py-2 text-sm w-64
                  placeholder-neutral-600 focus:outline-none focus:border-fuchsia-500" %>
    <%= form.submit "add + sync",
          class: "bg-fuchsia-700 hover:bg-fuchsia-600 text-white text-sm rounded px-4 py-2 cursor-pointer" %>
  <% end %>
</div>

<% if @repositories.empty? %>
  <p class="mt-16 text-neutral-500 text-center">
    No repositories yet. Add one above (for example <span class="text-neutral-300">akitaonrails/ai-memory</span>)
    and the first sync will start automatically.
  </p>
<% else %>
  <% max_commits = @repositories.map { |repository| @overview.for(repository).total_commits }.max %>

  <section class="mt-10">
    <p class="text-xs text-neutral-500 uppercase tracking-widest mb-3">+ commits land per repo</p>
    <div class="space-y-1.5">
      <% bar_colors = %w[bg-fuchsia-500 bg-orange-400 bg-cyan-400 bg-emerald-400 bg-pink-500 bg-violet-500 bg-amber-300 bg-sky-400] %>
      <% @repositories.sort_by { |repository| -@overview.for(repository).total_commits }.each_with_index do |repository, index| %>
        <% stats = @overview.for(repository) %>
        <div class="flex items-center gap-3 text-sm">
          <%= link_to repository.full_name, repository_path(owner: repository.owner, name: repository.name),
                class: "w-64 truncate text-neutral-300 hover:text-white" %>
          <div class="flex-1 h-3 bg-neutral-900 rounded-sm overflow-hidden">
            <div class="h-full rounded-sm <%= bar_colors[index % bar_colors.size] %>"
                 style="width: <%= max_commits.zero? ? 0 : (stats.total_commits * 100.0 / max_commits).clamp(stats.total_commits.zero? ? 0 : 1, 100).round(1) %>%"></div>
          </div>
          <span class="w-16 text-right text-neutral-400"><%= number_with_delimiter(stats.total_commits) %></span>
        </div>
      <% end %>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <% @repositories.each do |repository| %>
      <% stats = @overview.for(repository) %>
      <div class="border border-neutral-800 rounded-lg p-4 bg-neutral-950/60 hover:border-neutral-700">
        <div class="flex items-start justify-between gap-2">
          <div class="min-w-0">
            <%= link_to repository.full_name, repository_path(owner: repository.owner, name: repository.name),
                  class: "text-neutral-100 hover:text-fuchsia-300 font-semibold truncate block" %>
            <p class="text-xs text-neutral-500 truncate mt-0.5"><%= repository.description %></p>
          </div>
          <span class="shrink-0 inline-block w-2.5 h-2.5 rounded-full mt-1.5 <%= ci_dot_class(stats.ci_conclusion) %>"
                title="latest CI: <%= stats.ci_conclusion || "no runs" %>"></span>
        </div>

        <div class="flex gap-[3px] mt-4" title="commits per day, last <%= @overview.chip_dates.size %> days">
          <% stats.daily_counts.each do |count| %>
            <span class="h-4 flex-1 rounded-[2px]" style="background-color: <%= heat_color(count, stats.max_daily) %>"></span>
          <% end %>
        </div>

        <div class="flex items-center justify-between mt-4 text-xs">
          <span class="text-neutral-400">
            <%= number_with_delimiter(stats.total_commits) %> commits
            <span class="text-pink-400">+<%= number_with_delimiter(stats.total_additions) %></span>
            <span class="text-cyan-400">-<%= number_with_delimiter(stats.total_deletions) %></span>
          </span>
          <span class="border rounded-full px-2 py-0.5 <%= sync_status_class(repository.sync_status) %>">
            <%= repository.sync_status %>
          </span>
        </div>
      </div>
    <% end %>
  </section>
<% end %>
