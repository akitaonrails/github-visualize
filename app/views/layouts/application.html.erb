<!DOCTYPE html>
<html class="bg-[#0b0a10]">
  <head>
    <title><%= content_for(:title) || "GitHub Visualize" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-[#0b0a10] text-neutral-200 font-mono antialiased">
    <header class="border-b border-neutral-800/80">
      <div class="container mx-auto max-w-6xl px-5 py-4 flex items-center justify-between">
        <%= link_to root_path, class: "flex items-center gap-2 text-neutral-100 hover:text-white" do %>
          <span class="text-fuchsia-400">▦</span>
          <span class="tracking-tight font-semibold">github-visualize</span>
        <% end %>
        <span class="text-xs text-neutral-500 uppercase tracking-widest">repo progress, replayed</span>
      </div>
    </header>

    <% if notice.present? || alert.present? %>
      <div class="container mx-auto max-w-6xl px-5 pt-4">
        <% if notice.present? %>
          <p class="text-sm text-emerald-300 border border-emerald-900 bg-emerald-950/40 rounded px-3 py-2"><%= notice %></p>
        <% end %>
        <% if alert.present? %>
          <p class="text-sm text-red-300 border border-red-900 bg-red-950/40 rounded px-3 py-2"><%= alert %></p>
        <% end %>
      </div>
    <% end %>

    <main class="container mx-auto max-w-6xl px-5 py-8">
      <%= yield %>
    </main>
  </body>
</html>
